<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/maki_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Jual"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/stepperArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <View
            android:id="@+id/stepperProgress"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="30dp"
            android:layout_marginBottom="12dp"
            android:background="#6952D9" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <RelativeLayout android:id="@+id/bgStep1" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stepper_active">
                    <ImageView android:id="@+id/iconStep1" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerInParent="true" android:src="@android:drawable/ic_menu_camera" app:tint="#FFFFFF"/>
                </RelativeLayout>
                <TextView android:id="@+id/tvStep1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Foto" android:textSize="12sp" android:textColor="#6952D9" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <RelativeLayout android:id="@+id/bgStep2" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stepper_inactive">
                    <ImageView android:id="@+id/iconStep2" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerInParent="true" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="#BDBDBD"/>
                </RelativeLayout>
                <TextView android:id="@+id/tvStep2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Detail" android:textSize="12sp" android:textColor="#BDBDBD"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <RelativeLayout android:id="@+id/bgStep3" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stepper_inactive">
                    <ImageView android:id="@+id/iconStep3" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerInParent="true" android:src="@drawable/kategori" app:tint="#BDBDBD"/>
                </RelativeLayout>
                <TextView android:id="@+id/tvStep3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kategori" android:textSize="12sp" android:textColor="#BDBDBD"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <RelativeLayout android:id="@+id/bgStep4" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stepper_inactive">
                    <ImageView android:id="@+id/iconStep4" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerInParent="true" android:src="@drawable/question_mark" app:tint="#BDBDBD"/>
                </RelativeLayout>
                <TextView android:id="@+id/tvStep4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Kondisi" android:textSize="12sp" android:textColor="#BDBDBD"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <RelativeLayout android:id="@+id/bgStep5" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_stepper_inactive">
                    <ImageView android:id="@+id/iconStep5" android:layout_width="20dp" android:layout_height="20dp" android:layout_centerInParent="true" android:src="@drawable/done" app:tint="#BDBDBD"/>
                </RelativeLayout>
                <TextView android:id="@+id/tvStep5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Selesai" android:textSize="12sp" android:textColor="#BDBDBD"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomArea"
        android:layout_below="@+id/stepperArea"
        android:scrollbars="none">

        <ViewFlipper
            android:id="@+id/viewFlipperJual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/btnUploadFoto"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_dashed_border"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="#6952D9" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Upload foto barang"
                        android:textColor="#6952D9"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Maksimal 10 foto"
                        android:textColor="#757575"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:background="#D3D3D3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail Barang"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Nama Barang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaBarang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Harga Jual (Rp)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHarga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Deskripsi Barang"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeskripsi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:lines="4"
                        android:gravity="top" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Kategori"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupKategori"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPakaian"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pakaian" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSepatu"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sepatu" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTas"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tas" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipElektronik"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elektronik" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kondisi Barang"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupKondisi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBaru"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Baru" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSangatBaik"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sangat Baik" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBaik"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Baik" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCukup"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cukup" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/done"
                    app:tint="#4CAF50"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Barangmu Siap Dijual!"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pastikan semua data sudah benar sebelum mengunggah produk."
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </ViewFlipper>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp"
        android:background="#FFFFFF">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLanjutkan"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Lanjutkan"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:backgroundTint="#6952D9" />
    </LinearLayout>

</RelativeLayout>
